# ReadyPi Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================================================
# SERVER CONFIG
# ============================================================================
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=readypi
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_SSL=false

# ============================================================================
# JWT SECRET (Generate with: openssl rand -base64 32)
# ============================================================================
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters

# ============================================================================
# API KEY ENCRYPTION
# ============================================================================
API_KEY_SALT_ROUNDS=12

# ============================================================================
# AI PROVIDER API KEYS
# ============================================================================

# Groq (Free tier - Llama 3 70B)
GROQ_API_KEY=your_groq_api_key

# Google AI Studio (Free tier - Gemini 1.5 Flash)
GOOGLE_API_KEY=your_google_ai_studio_key

# DeepSeek (Paid - cheapest model)
DEEPSEEK_API_KEY=your_deepseek_api_key

# OpenAI (Paid - GPT-4o, GPT-4o Mini)
OPENAI_API_KEY=your_openai_api_key

# Anthropic (Paid - Claude Sonnet, Haiku)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Mistral (Paid - Mistral Small)
MISTRAL_API_KEY=your_mistral_api_key

# ============================================================================
# PAYMENT GATEWAYS
# ============================================================================

# SSLCommerz (bKash, Nagad, Rocket, Cards)
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASSWORD=your_store_password
SSLCOMMERZ_IS_LIVE=false
SSLCOMMERZ_SUCCESS_URL=http://localhost:3000/api/payment/success
SSLCOMMERZ_FAIL_URL=http://localhost:3000/api/payment/fail
SSLCOMMERZ_CANCEL_URL=http://localhost:3000/api/payment/cancel
SSLCOMMERZ_IPN_URL=http://localhost:3000/api/payment/ipn

# NOWPayments (USDT, BTC, Crypto)
NOWPAYMENTS_API_KEY=your_nowpayments_api_key
NOWPAYMENTS_IPN_SECRET=your_nowpayments_ipn_secret
NOWPAYMENTS_IS_SANDBOX=true

# ============================================================================
# RATE LIMITING (requests per minute by plan tier)
# ============================================================================
RATE_LIMIT_FREE=10
RATE_LIMIT_STARTER=60
RATE_LIMIT_PRO=200
RATE_LIMIT_TEAM=1000
RATE_LIMIT_ENTERPRISE=10000

# ============================================================================
# PRICING (BDT per 1M tokens)
# ============================================================================
PRICE_DEEPSEEK=0.90
PRICE_LLAMA=0.60
PRICE_GEMINI_FLASH=0.30
PRICE_GPT4O_MINI=0.60
PRICE_CLAUDE_HAIKU=2.50
PRICE_MISTRAL=0.70
PRICE_CLAUDE_SONNET=12.00
PRICE_GPT4O=10.00

# ============================================================================
# SUBSCRIPTION PLANS (BDT per month)
# ============================================================================
PLAN_STARTER_PRICE=499
PLAN_STARTER_CREDITS=10000
PLAN_PRO_PRICE=999
PLAN_PRO_CREDITS=25000
PLAN_TEAM_PRICE=2999
PLAN_TEAM_CREDITS=100000

# ============================================================================
# REFERRAL PROGRAM
# ============================================================================
REFERRAL_COMMISSION_PERCENT=20

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
LOG_FILE_PATH=./logs/readypi.log

# ============================================================================
# CORS (Frontend URLs)
# ============================================================================
CORS_ORIGIN=http://localhost:3001,https://readypi.io,https://dashboard.readypi.io

# ============================================================================
# EMAIL (Optional - for notifications)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@readypi.io

# ============================================================================
# MONITORING (Optional)
# ============================================================================
SENTRY_DSN=your_sentry_dsn
UPTIMEROBOT_API_KEY=your_uptimerobot_key
