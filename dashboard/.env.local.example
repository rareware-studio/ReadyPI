# =============================================================================
# ReadyPI Dashboard — Environment Variables
# =============================================================================
# Copy to .env.local and fill in values.
# NEXT_PUBLIC_ vars are exposed to the browser. Never put secrets here.

# ── Backend API ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Firebase Client SDK (from Firebase Console > Project Settings) ───────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=readypi-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=readypi-prod
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=readypi-prod.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Notes ────────────────────────────────────────────────────────────────────
# If NEXT_PUBLIC_FIREBASE_API_KEY is empty, the auth system will fall back
# to direct email/password login via the backend /auth/login endpoint.
# Firebase Auth is only required for Google/GitHub OAuth flows.
