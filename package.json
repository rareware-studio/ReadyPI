{
  "name": "readypi-api",
  "version": "1.0.0",
  "description": "ReadyPi AI API Aggregation Platform - Bangladesh's first AI gateway with bKash/Nagad payment",
  "main": "api/server.js",
  "scripts": {
    "dev": "nodemon api/server.js",
    "start": "node api/server.js",
    "test": "jest --coverage",
    "db:migrate": "psql readypi < database/schema.sql",
    "db:reset": "psql -c 'DROP DATABASE IF EXISTS readypi;' && psql -c 'CREATE DATABASE readypi;' && npm run db:migrate"
  },
  "keywords": [
    "ai",
    "api",
    "gateway",
    "openai",
    "anthropic",
    "bangladesh",
    "bkash",
    "nagad"
  ],
  "author": "Rareware Studio",
  "license": "PROPRIETARY",
  "dependencies": {
    "@dataconnect/generated": "file:src/dataconnect-generated",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "tiktoken": "^1.0.10",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
